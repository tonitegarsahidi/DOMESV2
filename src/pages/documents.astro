---
import MUIProvider from '../components/MUIProvider.jsx';
import Navbar from '../components/Navbar.jsx';
import FilterSidebar from '../components/FilterSidebar.jsx';
import DocumentList from '../components/DocumentList.jsx';
import Footer from '../components/Footer.jsx';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Documents | DOMES</title>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap"
    />
  </head>
  <body style="margin: 0; padding: 0; background: #f8fafc;">
    <MUIProvider client:load>
      <Navbar client:load />
      <div style={{ paddingTop: '80px', minHeight: '100vh' }}>
        
        {/* Subtle Hero Banner for Documents */}
        <div style={{ background: 'linear-gradient(90deg, #1e293b 0%, #334155 100%)', color: 'white', padding: '40px 20px', textAlign: 'center' }}>
          <h1 style={{ fontSize: '32px', fontWeight: '700', marginBottom: '12px' }}>Explore the Knowledge Repository</h1>
          <p style={{ fontSize: '16px', color: '#cbd5e1', maxWidth: '600px', margin: '0 auto' }}>Browse, filter, and access thousands of publications, research papers, and policy briefs from across all UN agencies.</p>
        </div>

        <div className="page-container" style={{ 
          display: 'flex', 
          maxWidth: '1400px', 
          margin: '0 auto', 
          padding: '40px 20px', 
          gap: '40px' 
        }}>
          <FilterSidebar client:load />
          
          <div className="results-content" style={{ flex: 1 }}>
            <DocumentList client:load searchQuery="" />
          </div>
        </div>
      </div>
      <Footer />
    </MUIProvider>
  </body>
</html>
